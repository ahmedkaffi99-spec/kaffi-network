# Copie ce fichier en .env et remplis-le avec tes vraies clés (mêmes clés
# que le site — voir .env.local.example à la racine du projet).
# Ce dossier tourne indépendamment du site Next.js, sur ta machine.

# API-Football (api-sports.io) — collecte des matchs et historiques
API_FOOTBALL_KEY=

# The Odds API (the-odds-api.com) — cotes bookmaker
ODDS_API_KEY=

# Serper (serper.dev) — actualités blessures/suspensions (optionnel)
SERPER_API_KEY=

# Telegram Bot — envoi du combiné sur le canal
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
